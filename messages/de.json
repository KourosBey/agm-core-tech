  "philosophy": {
    "badge": "Philosophie",
    "quoteTitle": "So arbeiten wir",
    "quote": "Wir bauen keine temporären Lösungen — wir entwickeln nachhaltige Architekturen, die sich an das Wachstumstempo Ihres Unternehmens anpassen. Wir erfüllen Ihre Anforderungen mit der richtigen Technologie und liefern eine unterbrechungsfreie, leistungsstarke digitale Infrastruktur.",
    "founder": {
      "name": "Atilla Görkem Meriç",
      "role": "Gründer & Chief Engineer, AGM Core Tech"
    },
    "pillars": {
      "precision": {
        "code": "CORE-01",
        "title": "Echte Bedarfsanalyse",
        "description": "Statt schneller Feature-Fixes setzen wir auf strategische Entwicklung, die Ihr Unternehmen voranbringt. Wir analysieren Ihre Abläufe im Detail und liefern präzise Lösungen für Ihre tatsächlichen Bedürfnisse."
      },
      "resilience": {
        "code": "CORE-02",
        "title": "Nachhaltige Architektur",
        "description": "Kein zusammengeflickter Code — wir bauen stabile Infrastruktur, die sich über Jahre an Ihr wachsendes Volumen anpasst. Jede Komponente ist darauf ausgelegt, Ressourcennutzung und Serverkosten zu optimieren."
      },
      "evolution": {
        "code": "CORE-03",
        "title": "Ununterbrochenes Vertrauen",
        "description": "Wir liefern jedes System, das wir entwickeln, nach höchsten Sicherheits- und Business-Continuity-Standards. Wir überlassen Ihre Technologie nicht dem Zufall — wir stellen sicher, dass Ihre digitalen Assets rund um die Uhr ohne Unterbrechung laufen."
      }
    }
  },
  "about": {
    "badge": "Core Genesis",
    "title": "Wachstumsreise",
    "subtitle": "Technologische Expansion — von der Stabilität der ersten Codezeile bis zur flexiblen AGM Core Tech-Infrastruktur, die Ihr Unternehmen in die Zukunft trägt.",
    "ringLabel": "Ring-Expansion beim Scrollen",
    "vision": "Unsere Vision ist es, komplexe Infrastrukturprobleme mit roher Engineering-Stärke zu lösen und Unternehmen unterbrechungsfreie Performance, Sicherheit und ein nachhaltiges Fundament für Wachstum in der digitalen Welt zu geben.",
    "founder": "AGM Core Tech",
    "stepsHeading": "Technologische Entwicklungsphasen",
    "steps": {
      "step1": {
        "label": "Phase 01",
        "title": "Discovery & Bedarfsanalyse",
        "description": "Wir erfassen Ihre aktuellen Abläufe, Engpässe und Wachstumsziele. Statt schneller Fixes definieren wir eine strategische Roadmap, die auf Ihre tatsächlichen Bedürfnisse ausgerichtet ist."
      },
      "step2": {
        "label": "Phase 02",
        "title": "Architekturdesign",
        "description": "Wir entwerfen nachhaltige, skalierbare Infrastruktur, die Kosten optimiert. Die Rolle und langfristige Eignung jeder Komponente im System wird klar definiert."
      },
      "step3": {
        "label": "Phase 03",
        "title": "Entwicklung & Integration",
        "description": "Wir entwickeln und verbinden Anwendungen, APIs und Drittanbietersysteme mit dem passenden Technologie-Stack. Stabilität und Performance haben von der ersten Codezeile an Priorität."
      },
      "step4": {
        "label": "Phase 04",
        "title": "Sicherheits- & Performance-Tests",
        "description": "Wir bringen das System durch Sicherheits-, Last- und Business-Continuity-Prüfungen auf Produktionsniveau. Unterbrechungsfreier Betrieb und hohe Performance-Ziele werden validiert."
      },
      "step5": {
        "label": "Phase 05",
        "title": "Launch & kontinuierliche Weiterentwicklung",
        "description": "Nach dem Go-Live passen Monitoring, Optimierung und iterative Entwicklung Ihre digitale Infrastruktur an wachsendes Volumen an und tragen sie in die Zukunft."
      }
    }
  },
